# Spiral 后端环境变量配置
# 请将本文件复制到 backend 目录下，或改名为 .env 后使用

# LLM API 配置（画像解析、专业匹配、报告生成均依赖 LLM）
# 必须配置，否则自由文本入口会报错
WINCODE_API_KEY=sk-your-api-key-here
WINCODE_BASE_URL=https://wincode.winning.com.cn/ai/v1

# 可选：OpenAI 兼容 Key 作为备用
# OPENAI_API_KEY=sk-xxx

# 联网搜索代理（Search Agent 补录数据时使用）
HTTP_PROXY=http://127.0.0.1:10793
HTTPS_PROXY=http://127.0.0.1:10793

# 首次初始化数据库时跳过 RAG 向量索引（加快 seed）
# SPIRAL_SKIP_RAG_SEED=1

# 服务端口号（默认 11678）
# PORT=11678
